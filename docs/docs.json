              "guides/keybindings",
              "guides/slash-commands",
              "guides/environment-setup",
              "guides/project-scoping"
            ]
          },
          {
            "group": "Developer Guide",
            "pages": [
              "development/setup",
              "development/server",
              "development/tui",
              "development/extending",
              "development/debugging"
            ]
          },
          {
            "group": "Architecture",
            "pages": [
              "architecture/overview",
              "architecture/server-design",
              "architecture/tui-design",
              "architecture/event-system",
